{
  "name": "ui",
  "path": "../../ui",
  "glob": "src/**/*.tsx",
  "useCase": { "notUsed": true },
  "eventHandler": { "notUsed": true },
  "domainOp": { "notUsed": true },
  "api": { "notUsed": true },
  "event": { "notUsed": true },
  "ui": {
    "find": "classes",
    "where": { "nameEndsWith": { "suffix": "Page" } },
    "extract": {
      "route": { "fromProperty": { "name": "route", "kind": "instance" } }
    }
  },
  "eventPublisher": { "notUsed": true }
}
